function TPrincipal.ValidarInfraestrutura(pdv, cpu, disco: Integer;
  memoria: Double): Boolean;
begin
  var
    minCPU, minMemoria, minDisco: Integer;

  begin
    Result := False;

    // memoria := FormatFloat('0', memoria);

    // 1. Identifica faixa
    if (pdv >= 1) and (pdv <= 100) then
    begin
      minCPU := 6;
      minMemoria := 4;
      minDisco := 128;
    end
    else if (pdv <= 200) then
    begin
      minCPU := 8;
      minMemoria := 8;
      minDisco := 256;
    end
    else if (pdv <= 600) then
    begin
      minCPU := 16;
      minMemoria := 16;
      minDisco := 512;
    end
    else if (pdv <= 1000) then
    begin
      minCPU := 24;
      minMemoria := 16;
      minDisco := 1024;
    end
    else if (pdv <= 1500) then
    begin
      minCPU := 32;
      minMemoria := 24;
      minDisco := 1024;
    end
    else if (pdv <= 2000) then
    begin
      minCPU := 48;
      minMemoria := 32;
      minDisco := 1536;
    end
    else
      Exit; // fora da regra

    // 2. Validação final (REGRA PRINCIPAL)
    Result := (cpu >= minCPU) and (memoria >= minMemoria) and
      (disco >= minDisco);
  end;

end;

